# ============================================
# Backend API URL (for production deployment)
# Set this to your deployed backend URL when hosting
# ============================================
VITE_API_URL=http://localhost:3000

# ============================================
# Finnhub API Key (Optional - for market data)
# Get free key at: https://finnhub.io/
# ============================================
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here

# ============================================
# Finnhub Base URL (optional)
# ============================================
VITE_FINNHUB_BASE_URL=https://finnhub.io/api/v1
